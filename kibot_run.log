          - layer: F.Mask
            color: '#CECECE'
          - layer: F.Paste
            color: '#CECECE'
          - layer: F.Silkscreen
            color: '#C7C7C7'
          - layer: F.Fab
            exclude_filter: 'only_testpoints'
            plot_footprint_values: false
